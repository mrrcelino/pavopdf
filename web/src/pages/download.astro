---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlatformDetector from '../components/PlatformDetector.svelte';

const releaseUrl = 'https://github.com/mrrcelino/pavopdf/releases/latest';

const platforms = [
  {
    id: 'windows',
    name: 'Windows',
    format: '.msi installer',
    icon: 'M3 5.5l7.5-1v7H3V5.5zm0 13l7.5 1v-7H3v6zm8.5 1.2L21 21V12h-9.5v7.7zm0-15.4V12H21V3l-9.5 1.3z',
    note: 'Windows 10 or later',
  },
  {
    id: 'macos',
    name: 'macOS',
    format: '.dmg disk image',
    icon: 'M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z',
    note: 'macOS 10.15 (Catalina) or later',
  },
  {
    id: 'linux',
    name: 'Linux',
    format: '.AppImage / .deb',
    icon: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z',
    note: 'Most modern distributions',
  },
];
---

<BaseLayout
  title="Download PavoPDF — Free PDF Tools for Windows, macOS, Linux"
  description="Download PavoPDF for free. Available for Windows (.msi), macOS (.dmg), and Linux (.AppImage). Open-source, offline PDF toolkit with 25 tools."
  canonicalPath="/download"
>
  <section class="bg-stone-950 text-cream py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">Download PavoPDF</h1>
      <p class="mt-4 text-lg text-stone-400">
        Free, open-source, and works on every major platform.
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
    <PlatformDetector client:load />
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6" id="platform-cards">
      {platforms.map((platform) => (
        <div
          class="bg-white border border-stone-200 rounded-lg p-6 text-center hover:shadow-md transition-shadow"
          data-platform={platform.id}
        >
          <div class="w-12 h-12 mx-auto mb-4 text-stone-700">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-12 h-12">
              <path d={platform.icon} />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-stone-900">{platform.name}</h2>
          <p class="text-sm text-stone-500 mt-1">{platform.format}</p>
          <a
            href={releaseUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center mt-5 px-6 py-2.5 bg-teal text-white font-semibold rounded-lg hover:bg-teal-dark transition-colors text-sm w-full"
          >
            Download for {platform.name}
          </a>
          <p class="text-xs text-stone-400 mt-3">{platform.note}</p>
        </div>
      ))}
    </div>

    <!-- System requirements -->
    <div class="mt-16 space-y-8">
      <div>
        <h2 class="text-xl font-bold text-stone-900 mb-4">System requirements</h2>
        <ul class="space-y-2 text-stone-600">
          <li class="flex items-start gap-2">
            <span class="text-teal mt-0.5">&#10003;</span>
            <span>PavoPDF is a native desktop application — no Node.js, Java, or runtime needed</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-teal mt-0.5">&#10003;</span>
            <span>Runs on Windows 10+, macOS 10.15+, and modern Linux distributions</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-teal mt-0.5">&#10003;</span>
            <span>Approximately 30 MB download size</span>
          </li>
        </ul>
      </div>

      <div>
        <h2 class="text-xl font-bold text-stone-900 mb-4">OCR requirement</h2>
        <p class="text-stone-600 leading-relaxed">
          The OCR tool requires <a href="https://github.com/tesseract-ocr/tesseract" target="_blank" rel="noopener noreferrer" class="text-teal hover:underline">Tesseract</a> to be installed separately on your system. Tesseract is free and open-source. PavoPDF includes setup instructions for each platform when you first use the OCR tool.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
