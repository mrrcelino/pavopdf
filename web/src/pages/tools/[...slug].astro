---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import { tools, getRelatedTools } from '../../data/tools';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
};

const { tool } = Astro.props;
const related = getRelatedTools(tool);

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: tool.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://pavopdf.com' },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://pavopdf.com/#organise' },
    { '@type': 'ListItem', position: 3, name: tool.title, item: `https://pavopdf.com/tools/${tool.slug}` },
  ],
};

const combinedJsonLd = [faqJsonLd, breadcrumbJsonLd];
---

<BaseLayout
  title={tool.metaTitle}
  description={tool.metaDescription}
  canonicalPath={`/tools/${tool.slug}`}
  jsonLd={combinedJsonLd}
>
  <!-- Breadcrumbs -->
  <div class="bg-stone-950 border-b border-stone-800">
    <nav class="max-w-4xl mx-auto px-4 sm:px-6 py-3" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm text-stone-400">
        <li><a href="/" class="hover:text-cream transition-colors">Home</a></li>
        <li class="text-stone-600">/</li>
        <li><a href={`/#${tool.categorySlug}`} class="hover:text-cream transition-colors">{tool.category}</a></li>
        <li class="text-stone-600">/</li>
        <li class="text-cream">{tool.title}</li>
      </ol>
    </nav>
  </div>

  <!-- Hero -->
  <section class="bg-stone-950 text-cream pb-16 pt-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <p class="text-sm text-teal font-medium mb-3">{tool.category}</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">{tool.title}</h1>
      <p class="mt-4 text-lg text-stone-400 max-w-2xl leading-relaxed">{tool.shortDescription}</p>
    </div>
  </section>

  <!-- Content -->
  <article class="max-w-4xl mx-auto px-4 sm:px-6 py-16 space-y-16">
    <!-- Description -->
    <section>
      <p class="text-lg text-stone-700 leading-relaxed">{tool.longDescription}</p>
    </section>

    <!-- How It Works -->
    <section>
      <h2 class="text-2xl font-bold text-stone-900 mb-8">How it works</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {tool.howItWorks.map((step) => (
          <div class="relative">
            <div class="w-10 h-10 rounded-full bg-teal text-white flex items-center justify-center font-bold text-lg mb-4">
              {step.step}
            </div>
            <h3 class="font-semibold text-stone-900 mb-2">{step.title}</h3>
            <p class="text-sm text-stone-600 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section>
      <h2 class="text-2xl font-bold text-stone-900 mb-6">Frequently asked questions</h2>
      <FAQ faqs={tool.faqs} />
    </section>

    <!-- Related Tools -->
    {related.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold text-stone-900 mb-6">Related tools</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {related.map((r) => (
            <a
              href={`/tools/${r.slug}`}
              class="block bg-white border border-stone-200 rounded-lg p-5 hover:shadow-md transition-shadow"
            >
              <h3 class="font-semibold text-stone-900 mb-1">{r.title}</h3>
              <p class="text-sm text-stone-500">{r.shortDescription}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Download CTA -->
    <section class="bg-stone-950 text-cream rounded-xl p-8 sm:p-12 text-center">
      <h2 class="text-2xl font-bold">Try {tool.title} in PavoPDF</h2>
      <p class="mt-3 text-stone-400">Free, open-source, and works offline.</p>
      <a
        href="/download"
        class="inline-flex items-center justify-center mt-6 px-8 py-3.5 bg-teal text-white font-semibold rounded-lg hover:bg-teal-dark transition-colors"
      >
        Download PavoPDF
      </a>
    </section>
  </article>
</BaseLayout>
