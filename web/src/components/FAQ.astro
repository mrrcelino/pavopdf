---
interface Props {
  faqs: { question: string; answer: string }[];
}

const { faqs } = Astro.props;
---

<div class="space-y-3">
  {faqs.map((faq) => (
    <details class="group border border-stone-200 rounded-lg bg-white">
      <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-left font-medium text-stone-900 hover:bg-stone-50 rounded-lg transition-colors">
        <span class="pr-4">{faq.question}</span>
        <svg
          class="w-5 h-5 text-teal shrink-0 transition-transform group-open:rotate-180"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </summary>
      <div class="px-5 pb-4 text-stone-600 leading-relaxed border-t border-stone-100 pt-3">
        {faq.answer}
      </div>
    </details>
  ))}
</div>
