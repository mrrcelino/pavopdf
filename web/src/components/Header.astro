---
import MobileMenu from './MobileMenu.svelte';
import { categories } from '../data/tools';
---

<header class="sticky top-0 z-50 bg-stone-950 border-b border-stone-800">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-xl font-bold text-teal tracking-tight">PavoPDF</a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      <!-- Tools dropdown -->
      <div class="relative group">
        <button
          class="text-stone-300 hover:text-cream text-sm font-medium flex items-center gap-1 py-2"
          aria-haspopup="true"
        >
          Tools
          <svg class="w-3.5 h-3.5 opacity-60" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150">
          <div class="bg-stone-900 border border-stone-700 rounded-lg shadow-xl py-2 w-56">
            {categories.map((cat) => (
              <a
                href={`/#${cat.slug}`}
                class="block px-4 py-2 text-sm text-stone-300 hover:text-cream hover:bg-stone-800 transition-colors"
              >
                {cat.name}
                <span class="text-stone-500 ml-1">({cat.count})</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <a href="/download" class="text-stone-300 hover:text-cream text-sm font-medium">Download</a>
      <a href="/about" class="text-stone-300 hover:text-cream text-sm font-medium">About</a>

      <!-- GitHub icon -->
      <a
        href="https://github.com/mrrcelino/pavopdf"
        target="_blank"
        rel="noopener noreferrer"
        class="text-stone-400 hover:text-cream transition-colors"
        aria-label="GitHub repository"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
      </a>
    </div>

    <!-- Mobile menu toggle -->
    <div class="md:hidden">
      <MobileMenu client:load />
    </div>
  </nav>
</header>
